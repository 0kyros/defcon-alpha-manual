# Caddyfile — production reverse proxy with automatic Let's Encrypt SSL
#
# Caddy obtains and renews TLS certificates for the listed hostnames
# automatically as long as ports 80 and 443 reach this container from the
# public Internet.
#
# To change domain: edit the hostnames below and `docker compose restart caddy`.

# Apex → www redirect (optional but conventional)
2k11c.shop {
	redir https://www.2k11c.shop{uri} 308
}

# Main site
www.2k11c.shop {
	encode zstd gzip

	# Security headers
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
		# Hide upstream identity
		-Server
	}

	# Long cache for Next.js static assets (immutable, content-hashed paths)
	@nextStatic path /_next/static/* /images/* /favicon.ico
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto https
	}

	# Health endpoint (used by uptime monitors)
	handle /healthz {
		respond "OK" 200
	}
}
